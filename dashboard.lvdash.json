{
  "datasets": [
    {
      "name": "kpis_resumo",
      "displayName": "KPIs Resumo",
      "queryLines": [
        "SELECT\n",
        "  j.job_id,\n",
        "  COALESCE(j.creator_user_name, j.creator_id) AS criador,\n",
        "  COUNT(DISTINCT r.run_id) AS total_execucoes,\n",
        "  COUNT(DISTINCT CASE WHEN r.result_state IN ('FAILED', 'ERROR', 'TIMED_OUT') THEN r.run_id END) AS execucoes_com_falha,\n",
        "  COUNT(DISTINCT CASE WHEN (unix_timestamp(r.period_end_time) - unix_timestamp(r.period_start_time)) > 3600 THEN r.run_id END) AS runs_longa_duracao\n",
        "FROM system.lakeflow.jobs j\n",
        "LEFT JOIN system.lakeflow.job_run_timeline r\n",
        "  ON j.job_id = r.job_id\n",
        "  AND j.workspace_id = r.workspace_id\n",
        "  AND r.period_start_time >= date_sub(current_date(), 30)\n",
        "WHERE j.delete_time IS NULL\n",
        "GROUP BY j.job_id, COALESCE(j.creator_user_name, j.creator_id)"
      ]
    },
    {
      "name": "tendencia_execucoes",
      "displayName": "Tendencia Execucoes",
      "queryLines": [
        "SELECT   j.job_id,   COALESCE(j.creator_user_name, j.creator_id) as criador,   DATE(r.period_start_time) as data,   COUNT(*) as total_execucoes,   SUM(CASE WHEN r.result_state = 'SUCCEEDED' THEN 1 ELSE 0 END) as sucesso,   COUNT(DISTINCT CASE WHEN r.result_state IN ('FAILED', 'ERROR', 'TIMED_OUT') THEN r.run_id END) as falha FROM system.lakeflow.job_run_timeline r JOIN system.lakeflow.jobs j ON r.job_id = j.job_id AND r.workspace_id = j.workspace_id WHERE r.period_start_time >= date_sub(current_date(), 30)   AND r.result_state IS NOT NULL   AND j.delete_time IS NULL GROUP BY j.job_id, COALESCE(j.creator_user_name, j.creator_id), DATE(r.period_start_time) ORDER BY data"
      ]
    },
    {
      "name": "distribuicao_status",
      "displayName": "Distribuicao Status",
      "queryLines": [
        "SELECT\n",
        "  j.job_id,\n",
        "  COALESCE(j.creator_user_name, j.creator_id) AS criador,\n",
        "  r.result_state AS status,\n",
        "  COUNT(DISTINCT r.run_id) AS quantidade\n",
        "FROM system.lakeflow.job_run_timeline r\n",
        "JOIN system.lakeflow.jobs j\n",
        "  ON r.job_id = j.job_id\n",
        "  AND r.workspace_id = j.workspace_id\n",
        "WHERE r.period_start_time >= date_sub(current_date(), 30)\n",
        "  AND r.result_state IS NOT NULL\n",
        "  AND j.delete_time IS NULL\n",
        "GROUP BY j.job_id, COALESCE(j.creator_user_name, j.creator_id), r.result_state"
      ]
    },
    {
      "name": "jobs_longa_duracao",
      "displayName": "Jobs Longa Duracao",
      "queryLines": [
        "SELECT   j.job_id,   COALESCE(j.creator_user_name, j.creator_id) as criador,   j.name as nome_job,   COALESCE(j.run_as_user_name, j.run_as) as executado_como,   r.run_id,   r.period_start_time as inicio,   r.period_end_time as fim,   r.result_state as status,   r.termination_code as codigo_termino,   ROUND((unix_timestamp(r.period_end_time) - unix_timestamp(r.period_start_time)) / 3600.0, 2) as duracao_horas,   COALESCE(j.timeout_seconds, 0) / 3600 as timeout_horas FROM system.lakeflow.job_run_timeline r JOIN system.lakeflow.jobs j ON r.job_id = j.job_id AND r.workspace_id = j.workspace_id WHERE r.period_start_time >= date_sub(current_date(), 30)   AND r.period_end_time IS NOT NULL   AND (unix_timestamp(r.period_end_time) - unix_timestamp(r.period_start_time)) > 3600   AND j.delete_time IS NULL ORDER BY duracao_horas DESC LIMIT 100"
      ]
    },
    {
      "name": "codigos_termino",
      "displayName": "Codigos Termino",
      "queryLines": [
        "WITH latest_jobs AS (\n",
        "  SELECT\n",
        "    workspace_id,\n",
        "    job_id,\n",
        "    COALESCE(creator_user_name, creator_id) AS criador\n",
        "  FROM\n",
        "    system.lakeflow.jobs\n",
        "  WHERE\n",
        "    delete_time IS NULL\n",
        "  QUALIFY\n",
        "    ROW_NUMBER() OVER (PARTITION BY workspace_id, job_id ORDER BY change_time DESC) = 1\n",
        "),\n",
        "last_slice AS (\n",
        "  SELECT\n",
        "    r.workspace_id,\n",
        "    r.job_id,\n",
        "    r.run_id,\n",
        "    r.termination_code\n",
        "  FROM\n",
        "    system.lakeflow.job_run_timeline r\n",
        "  WHERE\n",
        "    r.period_start_time >= date_sub(current_date(), 30)\n",
        "    AND r.termination_code IS NOT NULL\n",
        "  QUALIFY\n",
        "    ROW_NUMBER() OVER (PARTITION BY r.run_id ORDER BY r.period_end_time DESC) = 1\n",
        ")\n",
        "SELECT\n",
        "  j.job_id,\n",
        "  j.criador,\n",
        "  ls.termination_code AS codigo_termino,\n",
        "  COUNT(*) AS quantidade\n",
        "FROM\n",
        "  last_slice ls\n",
        "    JOIN latest_jobs j\n",
        "      ON ls.job_id = j.job_id\n",
        "      AND ls.workspace_id = j.workspace_id\n",
        "GROUP BY\n",
        "  j.job_id,\n",
        "  j.criador,\n",
        "  ls.termination_code"
      ]
    },
    {
      "name": "analise_config",
      "displayName": "Analise Configuracoes",
      "queryLines": [
        "SELECT\n",
        "  j.job_id,\n",
        "  COALESCE(j.creator_user_name, j.creator_id) AS criador,\n",
        "  j.name AS nome_job,\n",
        "  j.change_time AS data_hora_configuracao,\n",
        "  CASE\n",
        "    WHEN j.timeout_seconds IS NULL OR j.timeout_seconds = 0 THEN 'Sem Timeout'\n",
        "    ELSE 'Com Timeout'\n",
        "  END AS config_timeout,\n",
        "  j.timeout_seconds AS valor_timeout,\n",
        "  CASE\n",
        "    WHEN j.health_rules IS NULL OR SIZE(j.health_rules) = 0 THEN 'Sem Health Rules'\n",
        "    ELSE 'Com Health Rules'\n",
        "  END AS config_health_rules,\n",
        "  j.health_rules AS regras_configuradas,\n",
        "  CASE\n",
        "    WHEN j.tags IS NULL OR SIZE(j.tags) = 0 THEN 'Sem Tags'\n",
        "    ELSE 'Com Tags'\n",
        "  END AS config_tags,\n",
        "  j.tags as tags_configuradas,\n",
        "  CASE\n",
        "    WHEN j.run_as_user_name LIKE '%@%' THEN 'Usuario Pessoal'\n",
        "    WHEN j.run_as_user_name IS NOT NULL THEN 'Service Principal'\n",
        "    ELSE 'Nao Definido'\n",
        "  END AS tipo_identidade,\n",
        "  COALESCE(j.trigger_type, 'Manual') AS tipo_trigger,\n",
        "  CASE\n",
        "    WHEN j.paused = true THEN 'Pausado'\n",
        "    ELSE 'Ativo'\n",
        "  END AS status_job\n",
        "FROM system.lakeflow.jobs j\n",
        "WHERE j.delete_time IS NULL"
      ]
    },
    {
      "name": "resumo_problemas",
      "displayName": "Resumo Problemas",
      "queryLines": [
        "SELECT 'Sem Timeout' as problema, COUNT(DISTINCT job_id) as quantidade FROM system.lakeflow.jobs WHERE delete_time IS NULL AND (timeout_seconds IS NULL OR timeout_seconds = 0) UNION ALL SELECT 'Sem Health Rules', COUNT(DISTINCT job_id) FROM system.lakeflow.jobs WHERE delete_time IS NULL AND (SIZE(health_rules) = 0 OR health_rules IS NULL) UNION ALL SELECT 'Usuario Pessoal', COUNT(DISTINCT job_id) FROM system.lakeflow.jobs WHERE delete_time IS NULL AND run_as_user_name LIKE '%@%' UNION ALL SELECT 'Sem Tags', COUNT(DISTINCT job_id) FROM system.lakeflow.jobs WHERE delete_time IS NULL AND (SIZE(tags) = 0 OR tags IS NULL)"
      ]
    },
    {
      "name": "audit_jobs",
      "displayName": "Audit Jobs",
      "queryLines": [
        "SELECT\n",
        "  request_params['job_id'] AS job_id,\n",
        "  user_identity.email AS criador,\n",
        "  event_time AS data_hora,\n",
        "  action_name AS acao,\n",
        "  request_params as parametros,\n",
        "  response.status_code AS status_code\n",
        "FROM\n",
        "  system.access.audit\n",
        "WHERE\n",
        "  service_name = 'jobs'\n",
        "  AND event_time >= date_sub(current_date(), 7)\n",
        "  AND action_name IN ('create', 'update', 'delete', 'runNow', 'cancel', 'reset')\n",
        "ORDER BY\n",
        "  event_time DESC"
      ]
    }
  ],
